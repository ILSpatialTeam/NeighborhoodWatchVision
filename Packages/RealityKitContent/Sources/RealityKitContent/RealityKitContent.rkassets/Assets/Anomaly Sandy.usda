        def RealityKitComponent "AnimationLibrary"
        {
            token info:id = "RealityKit.AnimationLibrary"

            def RealityKitAnimationFile "Alfa_Walk"
            {
                uniform asset file = @../Animations/Alfa_Walk.usdc@
                uniform bool looping = 1
                uniform string name = "Alfa_Walk"
            }

            def RealityKitAnimationFile "default_subtree_animation"
            {
                uniform bool looping = 1
                uniform string name = "default subtree animation"
            }
        }

        def RealityKitComponent "RCP_BehaviorsContainer"
        {
            rel behaviors = [
                </Root/Alfa_Idle/OnAddedToScene>,
                </Root/Alfa_Idle/OnNotification>,
                </Root/Alfa_Idle/OnNotification2>,
            ]
            uniform token info:id = "RCP.BehaviorsContainer"
        }

        def Preliminary_Behavior "OnAddedToScene"
        {
            rel actions = </Root/Alfa_Idle/OnAddedToScene/Action>
            uniform bool exclusive
            rel triggers = </Root/Alfa_Idle/OnAddedToScene/Trigger>

            def Preliminary_Trigger "Trigger"
            {
                rel affectedObjects = </Root/Alfa_Idle>
                token info:id = "SceneTransition"
            }

            def Preliminary_Action "Action"
            {
                rel affectedObjects = </Root>
                rel animationLibraryKey = </Root/WalkIn>
                rel animationLibraryKeyOverrideKey = </Root/Alfa_Idle/OnAddedToScene/Trigger>
                token info:id = "PlayTimeline"
                int loops = 0
                int performCount = 1
                token type = "serial"
            }
        }

        def Preliminary_Behavior "OnNotification"
        {
            rel actions = </Root/Alfa_Idle/OnNotification/Action>
            uniform bool exclusive
            rel triggers = </Root/Alfa_Idle/OnNotification/Trigger>

            def Preliminary_Trigger "Trigger"
            {
                rel affectedObjects = </Root/Alfa_Idle>
                token info:id = "Notification"
            }

            def Preliminary_Action "Action"
            {
                rel affectedObjects = </Root>
                rel animationLibraryKey = </Root/Pass>
                rel animationLibraryKeyOverrideKey = </Root/Alfa_Idle/OnNotification/Trigger>
                token info:id = "PlayTimeline"
                int loops = 0
                int performCount = 1
                token type = "serial"
            }
        }

        def Preliminary_Behavior "OnNotification2"
        {
            rel actions = </Root/Alfa_Idle/OnNotification2/Action>
            uniform bool exclusive
            rel triggers = </Root/Alfa_Idle/OnNotification2/Trigger>

            def Preliminary_Trigger "Trigger"
            {
                rel affectedObjects = </Root/Alfa_Idle>
                string identifier = "Out"
                token info:id = "Notification"
            }

            def Preliminary_Action "Action"
            {
                rel affectedObjects = </Root>
                rel animationLibraryKey = </Root/Out>
                rel animationLibraryKeyOverrideKey = </Root/Alfa_Idle/OnNotification2/Trigger>
                token info:id = "PlayTimeline"
                int loops = 0
                int performCount = 1
                token type = "serial"
            }
        }

        over "_materials"
        {
            over "Alfa_TX"
            {
                asset inputs:BakedTexture = @../Texture/Characters/3D Sandy_Sandy_Fake_TX_BaseColor.1001.png@
            }
        }
    }

