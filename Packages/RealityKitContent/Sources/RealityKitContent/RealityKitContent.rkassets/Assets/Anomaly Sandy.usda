def Xform "Root"
{
    reorder nameChildren = ["WalkIn", "Out", "Pass"]
    def "Alfa_Idle" (
        active = true
        customData = {
            float3 rotationEulerHint = (1.5707965, -1.5707963, 0)
        }
        references = @../Animations/Alfa_Idle.usdc@
    )
    {
        quatf xformOp:orient = (0.5137515, -0.5137516, -0.48585933, -0.48585945)
        float3 xformOp:scale = (1, 1, 1)
        float3 xformOp:translate = (20, 0, -4.5)
