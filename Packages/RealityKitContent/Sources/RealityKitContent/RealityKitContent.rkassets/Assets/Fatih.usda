def Xform "Root"
{
    def "Fatih_Idle" (
        active = true
        customData = {
            float3 rotationEulerHint = (-1.5707965, 3.1415927, 2.3841858e-7)
        }
        references = @../Animations/Fatih_Idle.usdc@
