    {
        quatf xformOp:orient = (-1.1520231e-7, -5.338506e-8, 0.70710665, 0.7071069)
        float3 xformOp:scale = (1, 1, 1)
        float3 xformOp:translate = (4.5, 0.000001437962, 20)

        over "AnimationLibrary"
