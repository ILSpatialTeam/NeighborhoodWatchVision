                    token type = "cubicBezier"
                }
            }
        }

        def RealityKitTrack "Track5"
        {
            def RealityKitAction "Notification"
            {
                string actionKind = "notification"
                double duration = 0
                uniform token info:id = "310017C4-C724-457B-A72E-C752C6FC9161"
                string notificationName = "Arrived"
                double startTime = 9.241650842242116
                rel target = </Root/Fatih_Idle>
            }
        }
